name: ShadowHandHora
physics_engine: ${..physics_engine}
on_evaluation: False

env:
  numEnvs: ${resolve_default:64,${...num_envs}}

  # 3帧历史 * (qpos22 + target22) = 132
  numObservations: 132

  # 22 指 + 3 手臂 xyz
  numActions: 25

  envSpacing: 0.5
  episodeLength: 200            # ⚠ 改动：原 400，对"下降→抓→抬"足够,训练更快
  enableDebugVis: True
  aggregateMode: 1

  controller:
    torque_control: True
    controlFrequencyInv: 6
    pgain: 3
    dgain: 0.1

    # wrist lock (torque mode)
    wrist_pgain: 50.0
    wrist_dgain: 1.0
    wrist_torque_limit: 2.0
    finger_torque_limit: 0.8

    # 手臂 xyz 动作缩放
    arm_xyz_action_scale: 0.005
    arm_xyz_workspace:
      x: [-0.15, 0.15]
      y: [-0.15, 0.15]
      z: [0.02, 0.35]           # ⚠ 改动：下限 0.05→0.02, 让手能贴到球高度(球顶≈0.066)

  genGrasps: False
  clipObservations: 5.0
  clipActions: 1.0

  # ⚠ 改动：reset 判据改成"相对掉落",避免 ball 初始微沉就自触发
  reset_height_threshold: 0.015 # 球心 z < 1.5cm 才算掉地(球半径≈0.026,静止时≈0.026)

  grasp_cache_name: ''

  forceScale: 0.0
  randomForceProbScalar: 0.0
  forceDecay: 0.9
  forceDecayInterval: 0.08

  hora:
    propHistoryLen: 30
    privInfoDim: 9

  # 抓起并举高 reward
  reward:
    distScale: -1.0
    contactScale: 0.02
    liftScale: 10.0
    liftHeightThreshold: 0.05   # ⚠ 改动:0.08→0.05,更容易触发软 ramp 的第一段
    liftBonus: 5.0              # ⚠ 新增:超过阈值的额外 bonus(代码里配合软 ramp 用)
    actionPenaltyScale: -0.001
    armActionPenaltyScale: -0.001  # ⚠ 改动:-0.01→-0.001,原值 10x 会压手臂不敢动

  baseObjScale: 0.8

  # ⚠ 改动:先全部关掉,等 baseline 能抓起再逐项打开(HORA 的 priv_info 需要真值 DR)
  randomization:
    randomizeMass: False
    randomizeMassLower: 0.04         # ⚠ 改动:网球真实质量 ≈0.058,原 0.02 偏离太大
    randomizeMassUpper: 0.08         # ⚠ 改动:0.25→0.08
    randomizeCOM: False
    randomizeCOMLower: -0.005        # ⚠ 改动:球半径 2.6cm,±1cm 偏心过大
    randomizeCOMUpper: 0.005
    randomizeFriction: False
    randomizeFrictionLower: 0.5      # ⚠ 改动:0.3→0.5, 0.3 太滑基本抓不住
    randomizeFrictionUpper: 2.0      # ⚠ 改动:3.0→2.0
    randomizeScale: False
    # ⚠ 改动:scaleList 和 Lower/Upper 二选一,这里统一用 list
    scaleListInit: True
    randomizeScaleList: [0.7, 0.75, 0.8, 0.85]
    # randomizeScaleLower / Upper 删掉,避免和 list 冲突
    randomizePDGains: False
    randomizePGainLower: 0.8
    randomizePGainUpper: 1.2
    randomizeDGainLower: 0.8
    randomizeDGainUpper: 1.2
    jointNoiseScale: 0.0             # ⚠ 改动:0.02→0, baseline 阶段先干净训练

  privInfo:
    enableObjPos: True
    enableObjScale: True
    enableObjMass: True
    enableObjCOM: True
    enableObjFriction: True

  object:
    type: 'simple_tennis_ball'
    sampleProb: [1.0]
    # [x, y, z] in env-local coordinates.
    # ⚠ 改动:0.03→0.04,给 1cm 余量,避免初始帧穿模触发 reset
    initPos: [0.0, 0.0, 0.04]

  hand:
    # ⚠ 改动:initPos.z = object.initPos.z + approachHeight = 0.04 + 0.15 = 0.19
    initPos: [0.0, 0.0, 0.19]
    # initRot: [0.0, 0.0, 0.0, 1.0]
    extraYawDeg: 0.0
    fixBaseLink: False
    kinematicBase: False
    policyControlsArm: True
    approachHeight: 0.15
    alignToObject: True
    # ⚠ 新增:明确声明谁覆盖谁,代码里读这个 flag
    initPosOverriddenByAlign: True  # True 时 alignToObject 会重算 initPos

  fixInertia: True

  asset:
    # 注意:这里是相对于 asset_root 的路径(跟 Allegro 写法一致)
    handAsset: 'assets/shadow_hand_description/shadowhand_with_fingertips.urdf'

  enableCameraSensors: False

  debug:
    enable: True
    logOnce: True
    interval: 1000

sim:
  dt: 0.0083333                 # 1/120
  substeps: 1
  up_axis: 'z'
  use_gpu_pipeline: ${eq:${...pipeline},'gpu'}
  gravity: [0.0, 0.0, -9.81]
  physx:
    num_threads: ${....num_threads}
    solver_type: ${....solver_type}
    use_gpu: ${contains:'cuda',${....sim_device}}
    num_position_iterations: 8
    num_velocity_iterations: 0
    max_gpu_contact_pairs: 8388608
    num_subscenes: ${....num_subscenes}
    contact_offset: 0.002
    rest_offset: 0.0
    contact_collection: 2