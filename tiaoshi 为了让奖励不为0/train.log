-        self.extras['rotation_reward'] = rotate_reward.mean()
-        self.extras['object_linvel_penalty'] = object_linvel_penalty.mean()
-        self.extras['pose_diff_penalty'] = pose_diff_penalty.mean()
-        self.extras['work_done'] = work_penalty.mean()
-        self.extras['torques'] = torque_penalty.mean()
-        self.extras['roll'] = object_angvel[:, 0].mean()
-        self.extras['pitch'] = object_angvel[:, 1].mean()
-        self.extras['yaw'] = object_angvel[:, 2].mean()
@@ -364,0 +365,10 @@ class AllegroHandHora(VecTask):
+        # --- 3. 统计项更新 (用于 Tensorboard 和调试) ---
+        self.reset_buf[:] = self.check_termination(self.object_pos)
+        
+        # 计算当前物体到目标的距离，用于观察训练进度
+        goal_dist = torch.norm(target_pos - self.object_pos, p=2, dim=-1)
+        
+        self.extras['goal_dist'] = goal_dist.mean()
+        self.extras['palm_to_obj_dist'] = torch.norm(self.object_pos - palm_center, p=2, dim=-1).mean()
+        
+        # 如果是评估模式，更新评估统计
@@ -368,3 +377,0 @@ class AllegroHandHora(VecTask):
-            self.stat_sum_rotate_rewards += rotate_reward.sum()
-            self.stat_sum_torques += self.torques.abs().sum()
-            self.stat_sum_obj_linvel += (self.object_linvel ** 2).sum(-1).sum()
@@ -373,0 +381,4 @@ class AllegroHandHora(VecTask):
+            
+            # 记录成功率：距离目标小于 5cm 视为成功
+            success = (goal_dist <= 0.05).float()
+            
@@ -376,4 +387,2 @@ class AllegroHandHora(VecTask):
-                   f'eps length: {self.stat_sum_episode_length / self.env_evaluated:.2f} | ' \
-                   f'rotate reward: {self.stat_sum_rotate_rewards / self.env_evaluated:.2f} | ' \
-                   f'lin vel (x100): {self.stat_sum_obj_linvel * 100 / self.stat_sum_episode_length:.4f} | ' \
-                   f'command torque: {self.stat_sum_torques / self.stat_sum_episode_length:.2f}'
+                   f'goal_dist: {goal_dist.mean():.4f} | ' \
+                   f'success_rate: {success.sum() / self.num_envs:.2%}'
@@ -380,0 +390 @@ class AllegroHandHora(VecTask):
+            
@@ -605 +615 @@ class AllegroHandHora(VecTask):
-        allegro_hand_start_pose.p = gymapi.Vec3(0.0, 0.0, 0.5) 
+        allegro_hand_start_pose.p = gymapi.Vec3(0.0, 0.0, 0.2) 
@@ -634,0 +645,2 @@ class AllegroHandHora(VecTask):
+
+@torch.jit.script
@@ -636,5 +648,5 @@ def compute_hand_reward(
-    object_linvel_penalty, object_linvel_penalty_scale: float,
-    rotate_reward, rotate_reward_scale: float,
-    pose_diff_penalty, pose_diff_penalty_scale: float,
-    torque_penalty, torque_pscale: float,
-    work_penalty, work_pscale: float,
+    object_pos, object_rot, target_pos, target_rot,
+    palm_pos, fingertip_pos, actions,
+    # 以下参数在调用时，我们将传入 UniDexGrasp2 的原版数值
+    success_tolerance: float, reach_goal_bonus: float,
+    action_penalty_scale: float
@@ -642,6 +654,26 @@ def compute_hand_reward(
-    reward = rotate_reward_scale * rotate_reward
-    # Distance from the hand to the object
-    reward = reward + object_linvel_penalty * object_linvel_penalty_scale
-    reward = reward + pose_diff_penalty * pose_diff_penalty_scale
-    reward = reward + torque_penalty * torque_pscale
-    reward = reward + work_penalty * work_pscale
+    goal_dist = torch.norm(target_pos - object_pos, p=2, dim=-1)
+    palm_to_obj_dist = torch.norm(object_pos - palm_pos, p=2, dim=-1)
+    
+    # 唯一必须改的地方：Allegro 是 4 指，计算平均距离除以 4 (UniDex 原版是 5)
+    finger_dist = torch.norm(fingertip_pos - object_pos.unsqueeze(1), p=2, dim=-1)
+    avg_finger_dist = finger_dist.sum(dim=-1) / 4.0 
+
+    # --- 还原 UniDexGrasp2 原版阈值 ---
+    # 原版对于 Shadow Hand 的判定通常是手指距离 < 0.6, 掌心距离 < 0.12
+    is_approached = (avg_finger_dist <= 0.6).int() + (palm_to_obj_dist <= 0.12).int()
+    
+    # --- 还原 UniDexGrasp2 权重分配 ---
+    # 趋近奖励: 指尖 0.5, 掌心 1.0
+    reward = -0.5 * avg_finger_dist - 1.0 * palm_to_obj_dist
+    
+    # 对齐奖励: 触发后引导目标位置
+    goal_hand_rew = torch.where(is_approached == 2, 1.0 * (0.9 - 2.0 * goal_dist), torch.zeros_like(goal_dist))
+    reward += goal_hand_rew
+
+    # 成功奖励: 1.0 / (1 + 10 * dist) 这种非线性形式是 UniDex 的原版写法
+    bonus = torch.where(goal_dist <= success_tolerance, 1.0 / (1.0 + 10.0 * goal_dist), torch.zeros_like(goal_dist))
+    reward += bonus
+
+    # 动作惩罚: 还原为较大惩罚 (虽然 Allegro 轴少，但我们听你的，先用大的)
+    reward += action_penalty_scale * torch.sum(actions ** 2, dim=-1)
+
