-
+        self._refresh_gym()
+        
+        # --- 1. UniDexGrasp2 变量准备 ---
+        # 目标位姿 (通常为物体初始在桌面时的位置)
+        target_pos = self.object_init_state[:, 0:3]
+        target_rot = self.object_init_state[:, 3:7]
+        
+        # 获取 Allegro 手的 4 个指尖位置 (link_3/7/11/15_tip)
+        # 根据 URDF 索引通常为 4, 8, 12, 16
+        fingertip_pos = self.rigid_body_states[:, [4, 8, 12, 16], :3]
+
+        # 获取掌心位置：从 base_link (index 0) 向掌心方向偏移 0.08m
+        palm_state = self.rigid_body_states[:, 0, 0:7]
+        palm_pos = palm_state[:, 0:3]
+        palm_rot = palm_state[:, 3:7]
+        palm_center = palm_pos + quat_apply(palm_rot, to_torch([0, 0, 1], device=self.device).repeat(self.num_envs, 1) * 0.08)
+
+        # --- 2. 调用 UniDexGrasp2 核心奖励函数 ---
+        # 这里直接舍弃了原本的 rotate_reward 和 object_linvel_penalty
@@ -349,5 +353,10 @@ class AllegroHandHora(VecTask):
-            object_linvel_penalty, self.object_linvel_penalty_scale,
-            rotate_reward, self.rotate_reward_scale,
-            pose_diff_penalty, self.pose_diff_penalty_scale,
-            torque_penalty, self.torque_penalty_scale,
